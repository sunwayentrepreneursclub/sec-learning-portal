  loadRegister();
}

/* ═══════════════ INIT ═══════════════ */
if (SHEETS_API_URL.includes("PASTE_YOUR")) {
  app.innerHTML = `<div class="login-wrap"><div class="login-card">
    <div class="login-head"><img class="brand-mark lg" src="${LOGO_SRC}" alt="SEC logo"><h1>SEC Learning Portal</h1></div>
    <div class="err">Not configured yet: open this file and set <b>SHEETS_API_URL</b> at the top of the script to your deployed Apps Script web-app URL.</div>
  </div></div>`;
} else if (sessionToken && currentUser) {
  renderDashboard();
} else {
  renderLogin();
}
</script>
</body>
