/* ═══════════════ DASHBOARD ═══════════════ */
function renderDashboard() {
  const h = new Date().getHours();
  const tod = h < 12 ? "morning" : h < 18 ? "afternoon" : "evening";
  const first = (currentUser.name || "").split(" ")[0];
  const totalSubj = SUBJECTS.length;
  const doneSubj = SUBJECTS.filter(s => subjStatus(s) === "complete").length;

  const cards = SUBJECTS.map(subj => {
    const done = subjDoneCount(subj), total = subj.sections.length;
    const pct = Math.round(done / total * 100);
    const st = subjStatus(subj);
    const chip = st === "complete" ? `<span class="chip green">Complete</span>` : st === "in-progress" ? `<span class="chip amber">In progress</span>` : `<span class="chip grey">Not started</span>`;
    const circ = 2 * Math.PI * 26;
    return `<div class="card">
      <div class="row">
        <div class="ring-wrap">
          <svg class="ring" width="64" height="64" viewBox="0 0 64 64">
            <circle class="bg" cx="32" cy="32" r="26" fill="none" stroke-width="6"/>
            <circle class="fg" cx="32" cy="32" r="26" fill="none" stroke-width="6"
              stroke-dasharray="${circ}" stroke-dashoffset="${circ * (1 - pct/100)}"/>
          </svg>
          <div class="ring-num">${pct}%</div>
        </div>
        <div style="flex:1">
          <h3>${esc(subj.title)}</h3>
          <div class="desc">${esc(subj.description)}</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap">
        <div class="meta"><span>${total} sections</span><span>~${subj.estimatedMinutes} min</span>${chip}</div>
        <button class="btn btn-primary btn-sm" onclick="openSubject('${subj.id}')">${st === "not-started" ? "Start" : st === "complete" ? "Review" : "Continue"}</button>
      </div>
    </div>`;
  }).join("");

  app.innerHTML = topbar() + `<div class="shell">
    <h1 class="greeting">Good ${tod}, ${esc(first)}.</h1>
    <div class="role-badge">${esc(currentUser.role || "Member")}</div>
    <div class="overall">
      <div class="lbl">${doneSubj} of ${totalSubj} subject${totalSubj === 1 ? "" : "s"} complete</div>
      <div class="pbar"><div style="width:${totalSubj ? Math.round(doneSubj/totalSubj*100) : 0}%"></div></div>
    </div>
    <div class="cards">${cards}</div>
  </div>`;
}

/* ═══════════════ SUBJECT VIEW ═══════════════ */
let curSubj = null, curSecIdx = 0;

function openSubject(id) {
  curSubj = SUBJECTS.find(s => s.id === id);
  // land on first incomplete unlocked section
  curSecIdx = 0;
  for (let i = 0; i < curSubj.sections.length; i++) {
    if (secStatus(curSubj.id, curSubj.sections[i].id) !== "complete") { curSecIdx = i; break; }
    if (i === curSubj.sections.length - 1) curSecIdx = i;
  }
  renderSubject("reader");
}

function renderSubject(mode, payload) {
  const subj = curSubj;
  const sidebar = subj.sections.map((sec, i) => {
    const st = secStatus(subj.id, sec.id);
    const unlocked = sectionUnlocked(subj, i);
    let dot;
    if (st === "complete") dot = `<span class="sec-dot done">✓</span>`;
    else if (!unlocked) dot = `<span class="sec-dot">🔒</span>`;
    else if (st === "in-progress") dot = `<span class="sec-dot progress">${i+1}</span>`;
    else dot = `<span class="sec-dot">${i+1}</span>`;
    return `<button class="sec-item ${i === curSecIdx ? "active" : ""}" ${unlocked ? "" : "disabled"} onclick="gotoSection(${i})">${dot}<span>${esc(sec.title)}</span></button>`;
  }).join("");

  app.innerHTML = topbar() + `<div class="shell">
    <button class="back-link" onclick="renderDashboard()">← All subjects</button>
    <h1 style="font-size:26px;margin-bottom:4px">${esc(subj.title)}</h1>
    <p style="color:var(--muted);margin-bottom:22px">${esc(subj.description)}</p>
    <div class="subj-layout">
      <div class="sidebar">${sidebar}</div>
      <div class="subj-main" id="subj-main"></div>
    </div>
  </div>`;

  if (mode === "quiz") startQuiz();
  else if (mode === "section-complete") renderSectionComplete(payload);
  else if (mode === "subject-complete") renderSubjectComplete();
  else renderReader();
}

function gotoSection(i) {
  if (!sectionUnlocked(curSubj, i)) return;
  curSecIdx = i;
  renderSubject("reader");
}

/* ═══════════════ READER ═══════════════ */
function renderReader() {
  const subj = curSubj, sec = subj.sections[curSecIdx];
  const already = secStatus(subj.id, sec.id) === "complete";
  const sdExisting = secData(subj.id, sec.id);
  const hasPriorAttempt = !!(sdExisting && (sdExisting.attempts || []).length > 0);

  const clauses = sec.clauses.map(c => `<div class="clause-block">
    <div class="clause-label">${esc(c.label)}</div><p>${esc(c.text)}</p>
  </div>`).join("");

  let msg;
  if (already) msg = "You've already passed this section — review freely or retake the check.";
  else if (hasPriorAttempt) msg = "You've attempted this section before — retake the check whenever you're ready.";
  else msg = "Read through this section, then take the comprehension check whenever you're ready.";

  $("#subj-main").innerHTML = `
    <div class="reader-head">
      <div class="eyebrow">Section ${curSecIdx+1} of ${subj.sections.length} — ${esc(subj.title)}</div>
      <h1>${esc(sec.title)}</h1>
    </div>
    <div class="reader-body" id="reader-body">${clauses}</div>
    <div class="timer-banner" id="timer-banner">
      <span id="timer-msg">${msg}</span>
      <button class="btn btn-primary" id="quiz-btn">Take comprehension check →</button>
    </div>`;

  $("#quiz-btn").onclick = () => { renderSubject("quiz"); };
}

/* ═══════════════ QUIZ ═══════════════ */
let quiz = null;

async function startQuiz() {
  const subj = curSubj, sec = subj.sections[curSecIdx];
  $("#subj-main").innerHTML = `<div class="quiz-wrap" style="text-align:center;padding:70px 30px;color:var(--muted)"><span class="spin" style="border-color:var(--amber-line);border-top-color:var(--amber)"></span>&nbsp; Loading comprehension check…</div>`;
  const r = await api({ action: "getQuestions", subjectId: subj.id, sectionId: sec.id });
  if (r.error) { $("#subj-main").innerHTML = `<div class="quiz-wrap"><div class="err">${esc(r.error)}</div><button class="btn btn-ghost" onclick="renderSubject('reader')">← Back to reading</button></div>`; return; }
  quiz = { questions: r.questions, quizKey: r.quizKey, idx: 0, answers: new Array(r.questions.length).fill(null), started: Date.now() };
  renderQuestion();
}

function renderQuestion() {
  const q = quiz.questions[quiz.idx];
  const letters = "ABCD";
  const opts = q.options.map((opt, i) => `
    <button class="opt ${quiz.answers[quiz.idx] === opt ? "sel" : ""}" onclick="pickOption(${i})">
      <span class="letter">${letters[i] || i+1}</span><span>${esc(opt)}</span>
    </button>`).join("");
  const last = quiz.idx === quiz.questions.length - 1;
  $("#subj-main").innerHTML = `<div class="quiz-wrap">
    <div class="q-progress">Question ${quiz.idx+1} of ${quiz.questions.length}</div>
    <div class="q-text">${esc(q.q)}</div>
    ${opts}
    <div class="quiz-foot">
      <button class="btn btn-primary" id="q-next" ${quiz.answers[quiz.idx] === null ? "disabled" : ""}>${last ? "Submit answers" : "Next →"}</button>
    </div>
  </div>`;
  $("#q-next").onclick = () => {
    if (quiz.idx < quiz.questions.length - 1) { quiz.idx++; renderQuestion(); }
    else submitQuiz();
  };
}

function pickOption(i) {
  quiz.answers[quiz.idx] = quiz.questions[quiz.idx].options[i];
  renderQuestion();
}

async function submitQuiz() {
  const btn = $("#q-next");
  btn.disabled = true; btn.innerHTML = `<span class="spin"></span> Grading…`;
  const subj = curSubj, sec = subj.sections[curSecIdx];
  const timeSeconds = Math.round((Date.now() - quiz.started) / 1000);
  const r = await api({ action: "grade", quizKey: quiz.quizKey, answers: quiz.answers, timeSeconds });
  if (r.error) {
    $("#subj-main").innerHTML = `<div class="quiz-wrap"><div class="err">${esc(r.error)}</div><button class="btn btn-ghost" onclick="renderSubject('reader')">← Back to reading</button></div>`;
    return;
  }
  // sync progress from server
  try {
    const p = await api({ action: "getProgress" });
    if (p.data) { currentUser.data = p.data; saveUser(); }
  } catch(e) {}
  renderQuizResults(r, timeSeconds);
}

function renderQuizResults(r, timeSeconds) {
  const letters = "ABCD";
  const blocks = quiz.questions.map((q, qi) => {
    const res = r.results[qi];
    const opts = q.options.map((opt, i) => {
      const chosen = quiz.answers[qi] === opt;
      let cls = "";
      if (chosen && res.correct) cls = "right";
      else if (chosen && !res.correct) cls = "wrong";
      return `<div class="opt ${cls}" style="cursor:default">
        <span class="letter">${letters[i] || i+1}</span><span>${esc(opt)} ${chosen && res.correct ? "✓" : chosen ? "✗" : ""}</span>
      </div>`;
    }).join("");
    const explain = !res.correct && res.explain ? `<div class="explain">${esc(res.explain)}</div>` : "";
    return `<div style="margin-bottom:26px"><div class="q-text" style="font-size:16.5px">${qi+1}. ${esc(q.q)}</div>${opts}${explain}</div>`;
  }).join("");

  const passed = r.passed;
  const footer = passed
    ? `<button class="btn btn-primary" onclick="afterPass(${r.score},${r.total},${timeSeconds})">Continue →</button>`
    : `<button class="btn btn-primary" onclick="renderSubject('reader')">Review section and try again</button>`;

  $("#subj-main").innerHTML = `<div class="quiz-wrap">
    <div class="${passed ? "ok-note" : "err"}" style="font-size:15px">
      ${passed ? "Passed" : "Not quite"} — you scored <b>${r.score}/${r.total}</b>${passed ? "." : " (80% needed). Re-read the section, then the check will unlock again."}
    </div>
    ${blocks}
    <div class="quiz-foot">${footer}</div>
  </div>`;
}

function afterPass(score, total, timeSeconds) {
  const subj = curSubj;
  const allDone = subj.sections.every(s => secStatus(subj.id, s.id) === "complete");
  if (allDone) renderSubject("subject-complete");
  else renderSubject("section-complete", { score, total, timeSeconds });
}

function renderSectionComplete(p) {
  const subj = curSubj, sec = subj.sections[curSecIdx];
  const mins = Math.floor(p.timeSeconds / 60), secs = p.timeSeconds % 60;
  $("#subj-main").innerHTML = `<div class="celebrate">
    <div class="big">🎉</div>
    <h2>Section complete</h2>
    <p style="color:var(--muted)">${esc(sec.title)} — nicely done. That's another piece of the Charter you can act on.</p>
    <div class="stats">
      <div><b>${p.score}/${p.total}</b>Score</div>
      <div><b>${mins}m ${secs}s</b>Time taken</div>
    </div>
    <button class="btn btn-primary" onclick="nextSection()">Continue →</button>
  </div>`;
}

function nextSection() {
  if (curSecIdx < curSubj.sections.length - 1) { curSecIdx++; renderSubject("reader"); }
  else renderSubject("subject-complete");
}

function renderSubjectComplete() {
  const subj = curSubj;
  let totalTime = 0, totalScore = 0, totalMax = 0;
  subj.sections.forEach(s => {
    const d = secData(subj.id, s.id);
    if (d) {
      totalTime += d.timeSpentSeconds || 0;
      const best = (d.attempts || []).slice().reverse().find(a => a.total && (a.score/a.total) >= .8) || (d.attempts||[])[d.attempts.length-1];
      if (best) { totalScore += best.score; totalMax += best.total; }
    }
  });
  const avg = totalMax ? Math.round(totalScore/totalMax*100) : 0;
  $("#subj-main").innerHTML = `<div class="celebrate">
    <div class="big">🏆</div>
    <h2>${esc(subj.title)} — complete</h2>
    <p style="color:var(--muted);max-width:420px">Every section passed. You now know what you're here to do — and what the Charter expects of everyone else.</p>
    <div class="stats">
      <div><b>${subj.sections.length}</b>Sections</div>
      <div><b>${Math.round(totalTime/60)}m</b>Total time</div>
      <div><b>${avg}%</b>Avg score</div>
    </div>
    <button class="btn btn-primary" onclick="renderDashboard()">Back to all subjects →</button>
  </div>`;
}

