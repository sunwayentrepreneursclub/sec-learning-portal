      <table class="breakdown"><thead><tr><th>Section</th><th>Status</th><th>Best</th><th>Attempts</th><th>Time</th><th>Last attempt</th></tr></thead><tbody>${rows.join("")}</tbody></table>
      <h3 style="font-size:15px;margin-bottom:8px">Attempt history</h3>
      ${attBlocks.join("") || `<p style="color:var(--muted);font-size:13.5px">No attempts yet.</p>`}
      <div style="margin-top:22px"><button class="btn btn-danger btn-sm" onclick="delMember('${esc(m.email)}')">Delete member</button></div>
    </div>`;
}
