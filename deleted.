function openDetail(i) {
  const m = adminData.members[i];
  const rows = [];
  const attBlocks = [];
  SUBJECTS.forEach(subj => subj.sections.forEach(sec => {
    const d = m.subjects?.[subj.id]?.sections?.[sec.id];
    const st = d?.status || "not-started";
    const chip = st === "complete" ? `<span class="chip green">Complete</span>` : st === "in-progress" ? `<span class="chip amber">In progress</span>` : `<span class="chip grey">—</span>`;
    const atts = d?.attempts || [];
    const lastAtt = atts.length ? new Date(atts[atts.length-1].ts).toLocaleString() : "—";
    rows.push(`<tr><td>${esc(sec.title)}</td><td>${chip}</td><td>${d?d.bestScore:0}${atts.length?"/"+(atts[atts.length-1].total||"?"):""}</td><td>${atts.length}</td><td>${d?fmtTime(d.timeSpentSeconds||0):"—"}</td><td style="font-size:11.5px">${lastAtt}</td></tr>`);
    if (atts.length) {
      const inner = atts.map((a, ai) => {
        const qr = (a.questionResults||[]).map((q, qi) =>
          `<div class="qr">Q${qi+1}: Selected “${esc((q.selectedOption||"").slice(0,60))}${(q.selectedOption||"").length>60?"…":""}” <span class="${q.correct?"yes":"no"}">${q.correct?"✓":"✗"}</span></div>`).join("");
        return `<div class="att">
          <div class="hd">Attempt ${ai+1} (${new Date(a.ts).toLocaleString()}) — Score: ${a.score}/${a.total}
          ${a.total && a.score/a.total >= .8 ? '<span style="color:var(--green)">PASSED</span>' : ''}</div>
          ${qr}</div>`;
      }).join("");
      attBlocks.push(`<details class="attempts"><summary>${esc(sec.title)} — ${atts.length} attempt${atts.length>1?"s":""}</summary>${inner}</details>`);
    }
  }));

  $("#panel-root").innerHTML = `
    <div class="panel-overlay" onclick="closeDetail()"></div>
    <div class="detail-panel">
      <button class="back-link" onclick="closeDetail()">← Close</button>
      <h2>${esc(m.name)}</h2>
