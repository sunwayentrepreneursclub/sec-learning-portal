/* ═══════════════ PROGRESS HELPERS ═══════════════ */
function secStatus(subjId, secId) {
  const d = currentUser?.data?.subjects?.[subjId]?.sections?.[secId];
  return d?.status || "not-started";
}
function secData(subjId, secId) {
  return currentUser?.data?.subjects?.[subjId]?.sections?.[secId] || null;
}
function subjDoneCount(subj) {
  return subj.sections.filter(s => secStatus(subj.id, s.id) === "complete").length;
}
function subjStatus(subj) {
  const done = subjDoneCount(subj);
  if (done === subj.sections.length) return "complete";
  const any = subj.sections.some(s => secStatus(subj.id, s.id) !== "not-started");
  return any ? "in-progress" : "not-started";
}
function sectionUnlocked(subj, idx) {
  if (idx === 0) return true;
  return secStatus(subj.id, subj.sections[idx-1].id) === "complete";
}
function saveUser() { sessionStorage.setItem("sec_user", JSON.stringify(currentUser)); }

/* ═══════════════ LOGIN VIEW ═══════════════ */
function renderLogin(msg) {
  app.innerHTML = `
  <div class="login-wrap"><div class="login-card">
    <div class="login-head">
      <img class="brand-mark lg" src="${LOGO_SRC}" alt="SEC logo">
      <h1>SEC Learning Portal</h1>
      <div class="tagline">Know what you're here to do.</div>
    </div>
    ${msg ? `<div class="err">${esc(msg)}</div>` : ""}
    <div id="login-err"></div>
    <div class="field"><label>Full name</label><input id="li-name" autocomplete="name" placeholder="e.g. Amadeus Liew"></div>
    <div class="field"><label>Email address</label><input id="li-email" type="email" autocomplete="email" placeholder="you@imail.sunway.edu.my"></div>
    <div class="field"><label>Club password</label><input id="li-pw" type="password" placeholder="••••••••"></div>
    <button class="btn btn-primary" id="li-btn" style="width:100%">Enter the portal</button>
    <div class="login-foot"><button id="admin-link">Admin access →</button></div>
  </div></div>`;
  $("#li-btn").onclick = doLogin;
  $("#li-pw").addEventListener("keydown", e => { if (e.key === "Enter") doLogin(); });
  $("#admin-link").onclick = adminGate;
}

async function doLogin() {
  const name = $("#li-name").value.trim(), email = $("#li-email").value.trim(), password = $("#li-pw").value;
  const errBox = $("#login-err");
  errBox.innerHTML = "";
  if (!name || !email || !password) { errBox.innerHTML = `<div class="err">Fill in all three fields to continue.</div>`; return; }
  const btn = $("#li-btn");
  btn.disabled = true; btn.innerHTML = `<span class="spin"></span> Loading...`;
  try {
    const r = await api({ action: "login", name, email, password });
    if (r.error) { errBox.innerHTML = `<div class="err">${esc(r.error)}</div>`; btn.disabled = false; btn.textContent = "Enter the portal"; return; }
    sessionToken = r.token;
    currentUser = { name: r.name, email: email.toLowerCase().trim(), role: r.role, data: r.data };
    sessionStorage.setItem("sec_token", sessionToken);
    saveUser();
    renderDashboard();
  } catch(e) {
    errBox.innerHTML = `<div class="err">Could not reach the portal server. Check your connection and try again.</div>`;
    btn.disabled = false; btn.textContent = "Enter the portal";
  }
}

function adminGate() {
  const key = prompt("Enter admin key:");
  if (!key) return;
  sessionStorage.setItem("sec_admin_key", key);
  renderAdmin();
}

function signOut() {
  sessionStorage.removeItem("sec_token");
  sessionStorage.removeItem("sec_user");
  sessionToken = null; currentUser = null;
  renderLogin();
}

/* ═══════════════ SHELL ═══════════════ */
