function totalSections() { return SUBJECTS.reduce((n,s)=>n+s.sections.length,0); }
function fmtTime(s) {
  s = Math.round(s || 0);
  if (s < 60) return s + "s";
  const m = Math.floor(s / 60), r = s % 60;
  return r ? `${m}m ${r}s` : `${m}m`;
}

function memberStats(m) {
  let passed = 0, attempts = 0, time = 0, last = m.lastActive || 0;
  SUBJECTS.forEach(subj => subj.sections.forEach(sec => {
    const d = m.subjects?.[subj.id]?.sections?.[sec.id];
    if (!d) return;
    if (d.status === "complete") passed++;
    attempts += (d.attempts || []).length;
    time += d.timeSpentSeconds || 0;
  }));
  return { passed, attempts, time, last };
}

function renderMembersTab() {
  const total = totalSections();
  const ms = adminData.members;
  const started = ms.length;
  let cleared = 0, inprog = 0, totAtt = 0;
  const rows = ms.map((m, i) => {
    const s = memberStats(m);
    totAtt += s.attempts;
    if (s.passed === total) cleared++;
    else if (s.passed > 0 || s.attempts > 0) inprog++;
    const chip = s.passed === total ? `<span class="chip green">Complete</span>` : (s.passed>0||s.attempts>0) ? `<span class="chip amber">In progress</span>` : `<span class="chip grey">Not started</span>`;
    return `<tr onclick="openDetail(${i})">
      <td><b>${esc(m.name)}</b><br><span style="color:var(--muted);font-size:12px">${esc(m.email)}</span></td>
      <td><span class="role-badge" style="margin:0">${esc(m.role||"Member")}</span></td>
      <td><span class="minibar"><div style="width:${total?Math.round(s.passed/total*100):0}%"></div></span>${s.passed}/${total}</td>
      <td>${chip}</td>
      <td>${s.attempts}</td>
      <td>${fmtTime(s.time)}</td>
      <td style="font-size:12px;color:var(--muted)">${s.last ? new Date(s.last).toLocaleString() : "—"}</td>
      <td><button class="del-x" onclick="event.stopPropagation();delMember('${esc(m.email)}')" title="Delete member">✕</button></td>
    </tr>`;
  }).join("");

  const regWarn = adminData.registerCount === 0 ? `<div class="warn-banner">⚠ Register is empty — any email can log in with the club password. Add committee emails in Settings to enforce access control.</div>` : "";

