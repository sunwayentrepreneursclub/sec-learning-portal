async function handlePdfUpload(e) {
  const file = e.target.files[0];
  if (!file) return;
  $("#gen-msg").innerHTML = `<div class="ok-note">Extracting text from PDF…</div>`;
  try {
    if (!window.pdfjsLib) {
      await new Promise((res, rej) => {
        const s = document.createElement("script");
        s.src = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js";
        s.onload = res; s.onerror = rej;
        document.head.appendChild(s);
      });
      pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";
    }
    const buf = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument({ data: buf }).promise;
    let text = "";
    for (let p = 1; p <= pdf.numPages; p++) {
      const page = await pdf.getPage(p);
      const tc = await page.getTextContent();
      text += tc.items.map(i => i.str).join(" ") + "\n";
    }
    $("#gen-content").value = text.trim();
    $("#gen-msg").innerHTML = `<div class="ok-note">Extracted ${pdf.numPages} page${pdf.numPages>1?"s":""} of text. Review before generating.</div>`;
  } catch(err) {
    $("#gen-msg").innerHTML = `<div class="err">Couldn't read that PDF. Paste the text manually instead.</div>`;
  }
}

async function generateQuestions() {
  const content = $("#gen-content").value.trim();
  if (!content) { $("#gen-msg").innerHTML = `<div class="err">Add section content first — paste text or upload a PDF.</div>`; return; }
  const key = $("#gen-key").value.trim();
  const btn = $("#gen-btn");
  btn.disabled = true; btn.innerHTML = `<span class="spin"></span> Generating with Gemini…`;
  $("#gen-msg").innerHTML = "";
  try {
    if (key) {
      const rk = await api({ action: "setProp", key: "GEMINI_API_KEY", value: key, adminKey: adminKey() });
      if (rk.error) throw new Error(rk.error);
      $("#gen-key").value = "";
    }
    const subj = SUBJECTS.find(s => s.id === $("#gen-subj").value);
    const sec = subj.sections.find(s => s.id === $("#gen-sec").value);
    const r = await api({ action: "generateQuestions", subjectId: subj.id, sectionId: sec.id, sectionTitle: sec.title, content, adminKey: adminKey() });
    if (r.error) throw new Error(r.error);
    genQuestions = r.questions;
    renderGenResults(subj.id, sec.id, sec.title);
  } catch(err) {
    $("#gen-msg").innerHTML = `<div class="err">${esc(err.message || err)}</div>`;
  }
  btn.disabled = false; btn.textContent = "Generate questions";
}

function renderGenResults(subjectId, sectionId, sectionTitle) {
  const letters = "ABCD";
  const blocks = genQuestions.map((q, qi) => {
    const opts = q.options.map((o, oi) =>
      `<div class="go ${oi === q.correct ? "correct" : ""}"><span class="letter" style="width:22px;height:22px;font-size:11px;flex:none;border-radius:50%;background:var(--amber-soft);border:1px solid var(--amber-line);color:#92400E;display:flex;align-items:center;justify-content:center;font-weight:700">${letters[oi]}</span><span>${esc(o)} ${oi===q.correct?"✓ correct":""}</span></div>`).join("");
    return `<div class="gen-q" id="genq-${qi}">
      <div class="qt">${qi+1}. ${esc(q.q)}</div>${opts}
      <div class="ex">${esc(q.explain)}</div>
      <div class="acts">
        <button class="btn btn-ghost btn-sm" onclick="editGenQ(${qi})">Edit</button>
        <button class="btn btn-ghost btn-sm" style="color:var(--red)" onclick="delGenQ(${qi},'${subjectId}','${sectionId}','${esc(sectionTitle)}')">Delete</button>
      </div>
    </div>`;
  }).join("");
  $("#gen-results").innerHTML = `
    <h3 style="margin:22px 0 12px">Review generated questions — ${esc(sectionTitle)}</h3>
    ${blocks || `<p style="color:var(--muted)">No questions left. Generate again.</p>`}
    <div id="save-msg"></div>
    ${genQuestions.length ? `<button class="btn btn-primary" onclick="saveGenQuestions('${subjectId}','${sectionId}','${esc(sectionTitle)}')">Approve &amp; save to portal</button>` : ""}`;
}

function editGenQ(qi) {
  const q = genQuestions[qi];
  const nq = prompt("Question text:", q.q); if (nq === null) return;
  q.q = nq;
  for (let i = 0; i < q.options.length; i++) {
    const no = prompt(`Option ${"ABCD"[i]}${i===q.correct?" (correct)":""}:`, q.options[i]);
    if (no === null) break; q.options[i] = no;
  }
  const nc = prompt("Index of correct option (0–3):", q.correct);
  if (nc !== null && !isNaN(+nc) && +nc >= 0 && +nc < q.options.length) q.correct = +nc;
  const ne = prompt("Explanation:", q.explain); if (ne !== null) q.explain = ne;
  renderGenResults($("#gen-subj").value, $("#gen-sec").value, SUBJECTS.find(s=>s.id===$("#gen-subj").value).sections.find(s=>s.id===$("#gen-sec").value).title);
}

function delGenQ(qi, subjectId, sectionId, sectionTitle) {
  genQuestions.splice(qi, 1);
  renderGenResults(subjectId, sectionId, sectionTitle);
}

async function saveGenQuestions(subjectId, sectionId, sectionTitle) {
